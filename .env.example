# Example environment variables for deployment
# Add this in your Vercel project settings as environment variables (do NOT commit real keys).

# Preferred: SendGrid API key (free tier) — add this in Vercel env vars
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Fallback: Resend API key
RESEND_API_KEY=your_resend_api_key_here

# (Optional) Mailgun API key — not used by default
# MAILGUN_API_KEY=your_mailgun_api_key_here
